<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="it.unicam.cs.mpgc.rpg123388.view.HelloController">

    <VBox fx:id="selectionScreen" alignment="CENTER" spacing="35.0" style="-fx-background-color: #2b2b2b;">
        <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>

        <Label text="IL TUO PARTY" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #f39c12; -fx-font-family: 'Segoe UI', Tahoma, sans-serif; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.7), 8, 0, 0, 4);" />
        <Label text="Esamina i dettagli tattici scegli 3 avventurieri per il tuo party:" style="-fx-font-size: 19px; -fx-text-fill: #ecf0f1; -fx-font-family: 'Segoe UI', sans-serif;" />

        <HBox spacing="30" alignment="CENTER">
            <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-background-radius: 18; -fx-padding: 25; -fx-min-width: 230; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 6);">
                <Label text="Arthur" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Label text="Guerriero (Tank)" style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" />
                <Separator />
                <Label text="❤️ HP: 100 | ⚔️ Atk: 15" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 15px;" />
                <Separator />
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="⚔️ Fendente Pesante (Singolo)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="🛡️ Mura di Ferro (Party)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="      Effetto: Danni subiti **-10** (1 turno)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <CheckBox fx:id="chkWarrior" text="Seleziona" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2980b9; -fx-cursor: hand;" onAction="#onHeroSelectionChange"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-background-radius: 18; -fx-padding: 25; -fx-min-width: 230; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 6);">
                <Label text="Merlino" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;" />
                <Label text="Mago (Danno Area)" style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" />
                <Separator />
                <Label text="❤️ HP: 60 | ⚔️ Atk: 25" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 15px;" />
                <Separator />
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="✨ Tempesta Arcana (AoE)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="🔮 Saggezza (Buff Alleato)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="      Effetto: Attacco **+15** (1 turno)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <CheckBox fx:id="chkMage" text="Seleziona" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #8e44ad; -fx-cursor: hand;" onAction="#onHeroSelectionChange"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-background-radius: 18; -fx-padding: 25; -fx-min-width: 230; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 6);">
                <Label text="Panoramix" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                <Label text="Druido (Cura/Danno)" style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" />
                <Separator />
                <Label text="❤️ HP: 80 | ⚔️ Atk: 12" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 15px;" />
                <Separator />
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="🌿 Radici Stritolanti (Singolo)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="🧪 Elisir di Vita (Party)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="      Effetto: Cura **+20 HP** (Istantanea)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <CheckBox fx:id="chkDruid" text="Seleziona" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #27ae60; -fx-cursor: hand;" onAction="#onHeroSelectionChange"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-background-radius: 18; -fx-padding: 25; -fx-min-width: 230; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 6);">
                <Label text="Uther" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                <Label text="Paladino (Tank/Cura)" style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" />
                <Separator />
                <Label text="❤️ HP: 120 | ⚔️ Atk: 10" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 15px;" />
                <Separator />
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="🔨 Martello Divino (Singolo)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="☀️ Luce Divina (Party)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="      Effetto: Cura **+20 HP** (Istantanea)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <CheckBox fx:id="chkPaladin" text="Seleziona" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #f39c12; -fx-cursor: hand;" onAction="#onHeroSelectionChange"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-background-radius: 18; -fx-padding: 25; -fx-min-width: 230; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 6);">
                <Label text="Garrett" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
                <Label text="Ladro (Danno/SelfBuff)" style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" />
                <Separator />
                <Label text="❤️ HP: 60 | ⚔️ Atk: 20" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 15px;" />
                <Separator />
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="🗡️ Pugnalata alle Spalle (Singolo)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="🎯 Concentrazione (Self Buff)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <Label text="      Effetto: Attacco Personale **+15** (1 turno)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <CheckBox fx:id="chkThief" text="Seleziona" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #34495e; -fx-cursor: hand;" onAction="#onHeroSelectionChange"/>
            </VBox>
        </HBox>

        <Button fx:id="btnStart" text="Entra nel Dungeon!" disable="true" onAction="#onStartGameClick"
                style="-fx-font-size: 22px; -fx-padding: 18 50; -fx-cursor: hand; -fx-background-color: #e67e22; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 6, 0, 0, 4);" />
    </VBox>

    <VBox fx:id="gameScreen" alignment="CENTER" spacing="15.0" visible="false" managed="false" style="-fx-background-color: #f8f9fa;">
        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>

        <HBox alignment="CENTER" spacing="20">
            <Label fx:id="roomLabel" text="Stanza: 1" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI', sans-serif;" />
        </HBox>

        <HBox spacing="40" alignment="CENTER">
            <VBox fx:id="partyBox" spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 2; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" minWidth="280" />
            <Label text="VS" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c; -fx-font-style: italic;" />
            <VBox fx:id="enemyBox" spacing="15" alignment="CENTER_RIGHT" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 2; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" minWidth="280"/>
        </HBox>

        <TextArea fx:id="gameLog" editable="false" prefHeight="220.0" prefWidth="700.0"
                  style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 14px; -fx-control-inner-background: #ffffff; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" />

        <Separator />
        <VBox fx:id="commandCenterBox" spacing="15" alignment="CENTER" />

        <Separator />
        <Button text="Esegui Turno" onAction="#onAttackButtonClick"
                style="-fx-font-size: 18px; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-color: #27ae60; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.3), 4, 0, 0, 3);" />
    </VBox>
    <VBox fx:id="gameOverScreen" alignment="CENTER" spacing="20.0" visible="false" managed="false" style="-fx-background-color: #1a0505;">
        <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>

        <Label text="IL PARTY E' STATO SCONFITTO" style="-fx-font-size: 45px; -fx-font-weight: bold; -fx-text-fill: #e74c3c; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 10, 0, 0, 5);" />

        <Separator style="-fx-background-color: #c0392b; -fx-padding: 2;"/>

        <VBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: #c0392b; -fx-border-radius: 15; -fx-border-width: 2; -fx-min-width: 400;">
            <Label text="📜 Rapporto della Spedizione:" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f1c40f;" />

            <Label fx:id="statsLabel" text="[Dati in caricamento...]" style="-fx-font-size: 16px; -fx-text-fill: #ecf0f1; -fx-font-family: 'Consolas', monospace;" />
        </VBox>

        <Button text="Chiudi Gioco" onAction="#onExitClick"
                style="-fx-font-size: 18px; -fx-padding: 10 30; -fx-cursor: hand; -fx-background-color: #c0392b; -fx-background-radius: 5; -fx-text-fill: white; -fx-font-weight: bold;" />
    </VBox>
</StackPane>