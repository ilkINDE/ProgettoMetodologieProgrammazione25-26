<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg123388.view.HelloController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextArea fx:id="battleLogArea" editable="false" prefHeight="400.0" prefWidth="500.0"
              wrapText="true" style="-fx-font-family: 'Consolas'; -fx-font-size: 14px;"/>

    <Button text="Combatti! (Prossimo Turno)" onAction="#onNextTurnClick"
            style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
</VBox>